{
    "extends": "../../packages/config/tsconfig.json",
    "compilerOptions": {
        "types": ["vitest/globals"],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@craft/types": [
                "../../packages/types/src"
            ],
            "@craft/stellar": [
                "../../packages/stellar/src"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}